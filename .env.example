# OpenAI API Key (para CrewAI)
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Anthropic API Key (opcional - para Claude)
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Big Pickle / GLM-4.6 Configuration
BIG_PICKLE_ENABLED=false
BIG_PICKLE_MODEL=glm-4.6
BIG_PICKLE_API_KEY=your_big_pickle_api_key_here
BIG_PICKLE_BASE_URL=https://api.zai.com/v1
BIG_PICKLE_TEMPERATURE=0.7
BIG_PICKLE_MAX_TOKENS=4000

# LLM Selection (true = forzar Big Pickle, false = auto-detect)
USE_BIG_PICKLE=false

# LinkedIn MCP Configuration
LINKEDIN_MCP_ENABLED=true
LINKEDIN_MCP_SERVER_URL=http://localhost:3000

# CrewAI Configuration
CREWAI_PROCESS_TYPE=hierarchical
CREWAI_MEMORY_ENABLED=true
CREWAI_CACHE_ENABLED=true

# Job Search Configuration
DEFAULT_JOB_KEYWORDS=python,software engineer,developer
DEFAULT_LOCATION=remote
DEFAULT_JOB_TYPE=full-time

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Database (opcional - para persistencia)
DATABASE_URL=sqlite:///data/jobs.db